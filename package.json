{
  "name": "stormstore-linux",
  "version": "1.0.2",
  "description": "StormStore Linux",
  "author": "StormGamesStudios <meliodas.aitor@gmail.com>",
  "main": "main.js",
  "license": "",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --linux"
  },
  "devDependencies": {
    "electron": "^40.8.0",
    "electron-builder": "^26.8.1"
  },
  "dependencies": {
    "electron-updater": "^6.8.3"
  },
  "build": {
    "appId": "com.stormgamesstudios.stormstore",
    "productName": "StormStore",
    "directories": {
      "buildResources": "build"
    },
    "linux": {
      "target": ["AppImage", "deb"],
      "artifactName": "StormStore-Linux.${ext}",
      "icon": "./build/icon.png",
      "category": "Utility"
    },
    "publish": {
      "provider": "github",
      "owner": "acierto-incomodo",
      "repo": "stormstore-linux"
    }
  }
}